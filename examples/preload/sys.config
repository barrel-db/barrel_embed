[
    {barrel_embed, [
        %% Preload these models at application startup
        {preload_models, [
            {fastembed, <<"BAAI/bge-small-en-v1.5">>}
        ]},
        %% Venv path (set via BARREL_EMBED_VENV env var in Docker)
        {venv, undefined},
        %% 10 minute timeout for model download/load
        {preload_timeout, 600000}
    ]}
].
