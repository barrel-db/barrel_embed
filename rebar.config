{erl_opts, [debug_info]}.

{deps, [
    {hackney, "2.0.1"},
    {erlang_python, "1.5.0"}
]}.

{shell, [
    {apps, [barrel_embed]}
]}.

{profiles, [
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]},
        {eunit_opts, [verbose]}
    ]}
]}.

{dialyzer, [
    {warnings, [unknown]},
    {plt_apps, all_deps}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.
